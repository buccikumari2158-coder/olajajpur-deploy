# Jajpur Jatri — Expo environment variables
# Copy this file to .env.local and fill in real values.
# All EXPO_PUBLIC_* vars are bundled into the client at build time.

# ── Replit (set automatically by the Replit workflow) ───────────────────────
# EXPO_PUBLIC_DOMAIN=<your-replit-dev-domain>    # e.g. xxx.replit.dev
# EXPO_PUBLIC_REPL_ID=<your-repl-id>

# ── Firebase Phone Auth (required for OTP login) ────────────────────────────
# 1. Go to https://console.firebase.google.com/ → Create a project
# 2. Add an Android/iOS/Web app
# 3. Enable Authentication → Sign-in method → Phone
# 4. Copy the config values below from Project Settings → Your Apps → SDK setup
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Google Maps (already configured in app.json for Android) ─────────────────
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyBJBVLaN1gepg-gsp5jgNkmQqCIqs18m04

# ── Razorpay (set on the API server, not the mobile app) ─────────────────────
# RAZORPAY_KEY_ID=   (set in Replit Secrets for api-server)
# RAZORPAY_KEY_SECRET= (set in Replit Secrets for api-server)
